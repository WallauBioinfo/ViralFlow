# ViralFlow API — variáveis de ambiente
# Copie para .env e ajuste para seu servidor

# Chave secreta compartilhada com o MacWorp
API_KEY=troque-por-uma-chave-forte-aqui

# Caminho do executável Nextflow (dentro do env conda)
NEXTFLOW_BIN=nextflow

# Caminho para o pipeline principal do ViralFlow
VIRALFLOW_MAIN=/home/pinho/ViralFlow/vfnext/main.nf

# Diretório onde os jobs ficam armazenados
JOBS_BASE_DIR=/data/viralflow_jobs

# Nome do ambiente micromamba/conda
CONDA_ENV=viralflow

# Timeout por job em segundos (0 = sem limite)
JOB_TIMEOUT=0
